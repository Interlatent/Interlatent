# Build context tightening. The Dockerfile only COPYs from
# packages/server/, but Docker reads the entire context before
# evaluating COPY paths — excluding the heavy stuff here keeps
# the build fast on slow uplinks (GPU provider boxes especially).

# VCS / editors
.git
.gitignore
.gitattributes
.vscode
.idea
.DS_Store

# Python build artifacts
**/__pycache__
**/*.pyc
**/*.pyo
**/*.egg-info
**/.pytest_cache
**/.mypy_cache
**/.ruff_cache
**/.ipynb_checkpoints
.venv
venv
env

# JS — never needed for the GPU image
**/node_modules

# Heavy directories the GPU image doesn't need
data
datasets
outputs
runs
checkpoints
artifacts
*.sqlite
*.db
*.parquet
*.mp4
*.mkv
*.zip
*.tar
*.tar.gz

# Other packages we don't install in this image
packages/sdk
packages/teleop

# CI/local config that shouldn't leak into the image
.env
.env.*
*.local
.claude
docs
